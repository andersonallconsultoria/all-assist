# Runtime
NODE_ENV=development
LOG_LEVEL=info
LOG_FILE=logs/integration.log
STATE_FILE=data/state.json
CRM_DATA_FILE=data/crm.json
PUBLIC_BASE_URL=http://localhost:3000
POLL_INTERVAL_MS=60000
PORT=3000
# Empty = enabled for continuous mode and disabled for run:once.
ENABLE_HEALTH_SERVER=
DRY_RUN=false
FORCE_RESYNC=false

# ERP atual
# Informe IP/host, usuario e senha pela tela Integracao ERP ou por estas variaveis.
CISS_BASE_URL=
CISS_USERNAME=
CISS_PASSWORD=
CISS_CLIENT_ID=cisspoder-oauth
CISS_CLIENT_SECRET=poder7547
CISS_IDEMPRESA=1
CISS_PAGE_LIMIT=1000
# Use fixed dates for tests, or leave empty to use lookback/lookahead.
CISS_DTINI=
CISS_DTFIM=
CISS_LOOKBACK_DAYS=30
CISS_LOOKAHEAD_DAYS=180

# CRM / DKW
CRM_PROVIDER=local
CRM_BASE_URL=
CRM_API_KEY=replace-me
CRM_LEAD_WEBHOOK_URL=
CRM_DEFAULT_STEP=Entrada
CRM_DEFAULT_RESPONSIBLE=
CRM_STAGE_MAP_JSON={"PENDENTE":"Entrada","EFETIVADO":"Venda efetivada","FATURADO":"Gerou documento fiscal","NEGADO":"Pedido negado"}

# Keep false until DKW confirms order custom fields are mapped to the business.
# If true, order fields are sent in the webhook root payload.
CRM_SEND_ORDER_CUSTOM_FIELDS=false
CRM_SEND_CONTACT_FIELDS=true
CRM_FAIL_ON_REUSED_ORDER_ID=true

# The current white-label endpoint showed TLS issues during tests with curl -k.
# Keep true in production if the certificate is valid.
CRM_TLS_REJECT_UNAUTHORIZED=false

# HTTP behavior
HTTP_TIMEOUT_MS=30000
HTTP_RETRIES=2
HTTP_RETRY_DELAY_MS=1000

# Meta WhatsApp Cloud API
META_GRAPH_VERSION=v23.0
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=change-me
META_APP_SECRET=
META_MARK_INBOUND_READ=true

# ALL Assist auth bootstrap
ALLASSIST_BOOTSTRAP_ADMIN_NAME=Administrador
ALLASSIST_BOOTSTRAP_ADMIN_EMAIL=admin@allassist.local
ALLASSIST_BOOTSTRAP_ADMIN_PASSWORD=admin123
ALLASSIST_BOOTSTRAP_MASTER_NAME=Suporte ALL
ALLASSIST_BOOTSTRAP_MASTER_EMAIL=master@allassist.local
ALLASSIST_BOOTSTRAP_MASTER_PASSWORD=master123
ALLASSIST_SESSION_SECRET=change-this-secret
ALLASSIST_SESSION_TTL_HOURS=12

# Cofre de acessos (credenciais de clientes). Chave mestra de criptografia
# AES-256-GCM. DEFINA um valor forte e único em produção e NUNCA o altere depois
# de cadastrar credenciais (mudar a chave torna os segredos ilegíveis).
ALLASSIST_VAULT_KEY=change-this-vault-key

# SaaS / multiempresa
# Use wildcard DNS: *.*.allassist.com.br -> Load Balancer.
SAAS_BASE_DOMAIN=*.allassist.com.br
SAAS_MASTER_SUBDOMAIN=admin
SAAS_ACTIVE_TENANT_COOKIE=allassist_active_tenant

# Alertas operacionais via Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_SERVER_ERRORS=true
TELEGRAM_NOTIFY_INTEGRATION_FAILURES=true

# IA (classificador de tickets, apoio ao analista, leitura de PDF e bot).
# Sem esta chave, os recursos de IA caem em modo simplificado (sem Claude).
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
